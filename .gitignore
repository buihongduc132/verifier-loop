.verifier-loop/
*.salt

# ---- Editor / OS noise ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- pi local runtime (sessions, cache) ----
.pi/

# ---- Local notes / scratch ----
notes/
scratch/
*.local.md
_STATE.md

# ---- Dependencies vendored locally (avoid committing huge dirs) ----
/vendor/
/node_modules/
